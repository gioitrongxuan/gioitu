# Mẫu cấu hình production. Trên EC2, copy file này thành .env (cùng thư mục với
# docker-compose.prod.yml). TUYỆT ĐỐI KHÔNG commit file .env thật.

# Domain đã trỏ bản ghi A về IP công khai của EC2. Caddy sẽ tự cấp chứng chỉ
# Let's Encrypt cho domain này.
DOMAIN=app.example.com

# Mật khẩu Postgres của DB đi kèm (chuỗi ngẫu nhiên đủ mạnh).
#   openssl rand -hex 24
POSTGRES_PASSWORD=doi-thanh-chuoi-ngau-nhien-manh

# Khóa ký JWT đăng nhập. Tạo bằng:  openssl rand -hex 32
GIOITU_JWT_SECRET=doi-thanh-openssl-rand-hex-32

# (Tùy chọn) Ghim tag image cụ thể để rollback; mặc định dùng :latest.
# GIOITU_IMAGE=ghcr.io/gioitrongxuan/gioitu:<sha-commit-cu>
