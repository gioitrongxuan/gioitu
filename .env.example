# Optional backend configuration (server/src/index.ts)
# Port the Express backend listens on (frontend proxies /api here).
PORT=8787
# PostgreSQL connection string used by the backend (node-postgres).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gioitu
# Set PGSSL=1 (or add ?sslmode=require to DATABASE_URL) for managed Postgres.
# PGSSL=1
# Secret used to sign auth JWTs. CHANGE THIS in any real deployment.
GIOITU_JWT_SECRET=dev-insecure-secret-change-me
