# Optional backend configuration (server/src/index.ts)
# Port the Express backend listens on (frontend proxies /api here).
PORT=8787
# PostgreSQL connection string used by the backend (node-postgres).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gioitu
# Set PGSSL=1 (or add ?sslmode=require to DATABASE_URL) for managed Postgres.
# PGSSL=1
# Secret used to sign auth JWTs. CHANGE THIS in any real deployment.
GIOITU_JWT_SECRET=dev-insecure-secret-change-me
# Google OAuth client id for "Sign in with Google" (OAuth 2.0 Client ID of type
# "Web application" from Google Cloud Console). The frontend reads it from the
# server via /api/auth/config, so no rebuild is needed. Not secret. Sign-in is
# disabled while this is unset (guest mode still works).
GOOGLE_CLIENT_ID=
# Deepseek API key cho tính năng "sinh từ vựng bằng AI" ở màn Từ điển cá nhân
# (POST /api/ai/generate-vocab, cần đăng nhập). API tương thích OpenAI. Khi để
# trống, endpoint trả 503; người dùng vẫn dùng được "Lấy Prompt" + dán tay.
DEEPSEEK_API_KEY=
