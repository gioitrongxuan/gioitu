# Không dấu "/" cuối: bỏ qua CẢ thư mục node_modules lẫn symlink cùng tên mà
# worktree tạm tạo ra (mẫu "node_modules/" chỉ khớp thư mục, để lọt symlink).
node_modules
dist/
*.tsbuildinfo
*.local
.env
.env.*
!.env.example
!.env.prod.example

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
coverage/

# Local server database (SQLite)
server/*.db
server/*.db-shm
server/*.db-wal

# Reference clone of the upstream Yomitan source
yomitan/

# Imported dictionary data dumps (re-importable via the UI; not source)
wty-*/

# Reference data dumps & upstream clones (huge; re-importable, not source)
ref/
yomitan-api/
